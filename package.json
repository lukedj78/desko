{
  "name": "desko",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "turbo run build --filter=!@desko/web",
    "dev": "turbo run dev --filter=!@desko/web",
    "lint": "turbo run lint --filter=!@desko/web",
    "type-check": "turbo run type-check --filter=!@desko/web",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yml,yaml}\""
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@types/node": "^25.9.2",
    "prettier": "^3.3.3",
    "turbo": "^2.5.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
