      "types": "./templates/verify-email.tsx",
      "default": "./templates/verify-email.tsx"
    },
    "./templates/welcome": {
      "types": "./templates/welcome.tsx",
      "default": "./templates/welcome.tsx"
    },
    "./templates/invite": {
      "types": "./templates/invite.tsx",
      "default": "./templates/invite.tsx"
    },
    "./templates/ban-notice": {
      "types": "./templates/ban-notice.tsx",
      "default": "./templates/ban-notice.tsx"
    },
    "./templates/password-changed": {
      "types": "./templates/password-changed.tsx",
      "default": "./templates/password-changed.tsx"
    },
    "./templates/login-alert": {
      "types": "./templates/login-alert.tsx",
